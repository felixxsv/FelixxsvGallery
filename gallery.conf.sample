base_url = "https://gallery.felixxsv.net"

[app]
gallery = "vrchat"
timezone = "Asia/Tokyo"
cookie_secure = false

[db]
host = "127.0.0.1"
port = 3306
user = "gallery"
password = "gallery-password"
database = "felixxsv_gallery"

[auth]
verify_code_expires_sec = 900
two_factor_code_expires_sec = 300
reset_token_expires_sec = 1800
verify_resend_cooldown_sec = 60
two_factor_resend_cooldown_sec = 60
verify_max_attempts = 5
two_factor_max_attempts = 5

[paths]
source_root = "/data/felixxsv-gallery/source/vrchat/gallery"
original_cache_root = "/data/felixxsv-gallery/cache"
storage_root = "/data/felixxsv-gallery/www/storage"
quarantine_root = "/data/felixxsv-gallery/quarantine"

[smtp]
host = "192.168.10.112"
port = 25
use_starttls = false
use_auth = false
from_email = "noreply@felixxsv.net"
from_name = "Felixxsv Gallery"

[discord]
client_id = ""
client_secret = ""
redirect_uri = "https://gallery.felixxsv.net/api/auth/discord/callback"

[discord_bot]
token = ""
guild_id = 0
watch_channel_ids = [0]
max_files = 20
public_default = true
